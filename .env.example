# Copy to .env and fill in the values. All variables are documented in
# src/env.ts (validated at startup via defineEnvVars).

# --- Database ---------------------------------------------------------------
# PostgreSQL connection string (Prisma).
DATABASE_URL=postgres://user:password@localhost:5432/vryne

# --- Better Auth ------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of the app. MUST match the dev server port — the dev script
# runs on the default port 5173 with --strictPort, so the value below just works.
BETTER_AUTH_URL=http://localhost:5173

# --- Social logins (the only sign-in methods) --------------------------------
# Google: https://console.cloud.google.com/apis/credentials
#   Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook: https://developers.facebook.com/apps/
#   Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- Optional ----------------------------------------------------------------
# Production only (adapter-node): public origin for CSRF/form checks.
# Set to the same value as BETTER_AUTH_URL, e.g. https://your-app.up.railway.app
#ORIGIN=

# Dev-only time travel: initial offset (ms) added to the game clock.
#VRYNE_TIME_OFFSET_MS=0

# LLM-generated news headlines (falls back to templates when unset).
#GLM_API_KEY=
#GLM_BASE_URL=
#GLM_MODEL=
